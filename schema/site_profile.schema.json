{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ahxgw/site_wise/schema/site_profile.schema.json",
  "title": "Site Wise Profile",
  "description": "Structured profile for a high-traffic website analyzed by Site Wise.",
  "type": "object",
  "required": [
    "host",
    "category",
    "analysis_date",
    "summary",
    "business_model",
    "user_intents",
    "moat",
    "risks",
    "sources"
  ],
  "$defs": {
    "evidence": {
      "type": "string",
      "enum": ["verified", "inferred", "open"],
      "description": "Evidence strength for a claim. verified = primary or reliable secondary source; inferred = reasoned from public signals; open = unknown or contested."
    },
    "datedClaim": {
      "type": "object",
      "required": ["value", "as_of"],
      "properties": {
        "value": { "type": ["string", "number"] },
        "as_of": {
          "type": "string",
          "format": "date",
          "description": "When this number was true. Required because numbers decay."
        },
        "source": { "type": "string" },
        "source_url": { "type": "string", "format": "uri" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "host": {
      "type": "string",
      "description": "Primary host, such as youtube.com."
    },
    "canonical_url": {
      "type": "string",
      "format": "uri"
    },
    "analysis_date": {
      "type": "string",
      "format": "date"
    },
    "category": {
      "type": "string",
      "description": "Primary category, such as video platform, search engine, ecommerce, news, AI assistant, or sports media."
    },
    "subcategories": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "summary": {
      "type": "string",
      "description": "One or two sentence explanation of what the site is and why it matters."
    },
    "owner": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parent_company": { "type": "string" },
        "country": { "type": "string" },
        "ownership_notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "founding": {
      "type": "object",
      "properties": {
        "launched_year": { "type": "integer" },
        "founded_year": { "type": "integer" },
        "founders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "origin_story": { "type": "string" }
      },
      "additionalProperties": false
    },
    "markets": {
      "type": "object",
      "properties": {
        "primary_regions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "primary_languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "market_notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "user_intents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["intent", "importance"],
        "properties": {
          "intent": { "type": "string" },
          "importance": {
            "type": "string",
            "enum": ["primary", "secondary", "emerging"]
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "traffic": {
      "type": "object",
      "properties": {
        "traffic_score": { "type": "number" },
        "authority_score": { "type": "number" },
        "likely_sources": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["direct", "search", "social", "referral", "paid", "app", "email", "unknown"]
          }
        },
        "distribution_notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "key_metrics": {
      "type": "object",
      "description": "Quantitative anchors. Every entry must carry an as-of date.",
      "properties": {
        "monthly_active_users": { "$ref": "#/$defs/datedClaim" },
        "daily_active_users": { "$ref": "#/$defs/datedClaim" },
        "annual_revenue_usd": { "$ref": "#/$defs/datedClaim" },
        "revenue_mix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stream", "share", "as_of"],
            "properties": {
              "stream": { "type": "string" },
              "share": { "type": "string", "description": "Percentage or qualitative weight." },
              "as_of": { "type": "string", "format": "date" },
              "source": { "type": "string" },
              "source_url": { "type": "string", "format": "uri" },
              "evidence": { "$ref": "#/$defs/evidence" }
            },
            "additionalProperties": false
          }
        },
        "top_regions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["region", "as_of"],
            "properties": {
              "region": { "type": "string" },
              "share": { "type": "string" },
              "as_of": { "type": "string", "format": "date" },
              "source": { "type": "string" },
              "source_url": { "type": "string", "format": "uri" },
              "evidence": { "$ref": "#/$defs/evidence" }
            },
            "additionalProperties": false
          }
        },
        "content_inventory": { "$ref": "#/$defs/datedClaim" },
        "growth_direction": { "$ref": "#/$defs/datedClaim" },
        "other": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value", "as_of"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": ["string", "number"] },
              "as_of": { "type": "string", "format": "date" },
              "source": { "type": "string" },
              "source_url": { "type": "string", "format": "uri" },
              "evidence": { "$ref": "#/$defs/evidence" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "product": {
      "type": "object",
      "properties": {
        "core_journeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "supply_side": { "type": "string" },
        "demand_side": { "type": "string" },
        "notable_features": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "business_model": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "advertising",
          "subscription",
          "commission",
          "marketplace",
          "ecommerce",
          "licensing",
          "enterprise",
          "payments",
          "affiliate",
          "data",
          "donation",
          "unknown",
          "other"
        ]
      }
    },
    "moat": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "network_effects",
              "content_library",
              "data",
              "brand",
              "distribution",
              "technical",
              "regulatory",
              "trust",
              "ecosystem",
              "operations",
              "other"
            ]
          },
          "description": { "type": "string" },
          "evidence": { "$ref": "#/$defs/evidence" },
          "fragility": {
            "type": "string",
            "description": "Conditions under which this moat could erode."
          }
        },
        "additionalProperties": false
      }
    },
    "peers": {
      "type": "array",
      "description": "Comparable peers for contrast analysis. Each entry forces an explicit similarity and difference.",
      "items": {
        "type": "object",
        "required": ["host", "similarity", "difference"],
        "properties": {
          "host": { "type": "string" },
          "relation": {
            "type": "string",
            "enum": ["direct_competitor", "category_peer", "regional_analog", "successor", "predecessor", "adjacent", "other"]
          },
          "similarity": { "type": "string" },
          "difference": { "type": "string" },
          "lesson": { "type": "string", "description": "What the contrast teaches about this site." }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "technical_signals": {
      "type": "object",
      "properties": {
        "cdn": { "type": "string" },
        "hosting": { "type": "string" },
        "frontend": { "type": "string" },
        "security": { "type": "string" },
        "performance_notes": { "type": "string" },
        "integration_notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "search_perspective": {
      "type": "object",
      "description": "How this site behaves when treated as an information source for indexing, retrieval, or agent tool use.",
      "properties": {
        "identifier_scheme": {
          "type": "string",
          "description": "Stable IDs (e.g., YouTube videoId) and URL aliases that resolve to the same resource."
        },
        "canonical_url_rules": { "type": "string" },
        "crawl_policy": {
          "type": "object",
          "properties": {
            "robots_txt": { "type": "string" },
            "paywall": { "type": "boolean" },
            "login_wall": { "type": "boolean" },
            "geo_wall": { "type": "boolean" },
            "age_wall": { "type": "boolean" },
            "bot_defenses": { "type": "string", "description": "Cloudflare, Datadome, JS challenge, rate limiting, etc." },
            "ai_training_policy": { "type": "string", "description": "llms.txt, public stance on AI training scrapes." }
          },
          "additionalProperties": false
        },
        "official_apis": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "auth": { "type": "string" },
              "quota": { "type": "string" },
              "notes": { "type": "string" }
            },
            "additionalProperties": false
          },
          "default": []
        },
        "structured_data": {
          "type": "array",
          "description": "Which of these the site exposes: rss, atom, sitemap, opensearch, oembed, jsonld, microdata, opengraph.",
          "items": {
            "type": "string",
            "enum": ["rss", "atom", "sitemap", "opensearch", "oembed", "jsonld", "microdata", "opengraph", "other"]
          },
          "default": []
        },
        "retrieval_unit": {
          "type": "string",
          "description": "The granularity that is actually useful to retrieve: page, post, transcript segment, message, product, etc."
        },
        "authoritative_field": {
          "type": "string",
          "description": "When title, description, body, transcript, OCR disagree, which one carries the content signal? Where does SEO distortion live?"
        },
        "freshness": {
          "type": "object",
          "properties": {
            "mutability": {
              "type": "string",
              "enum": ["immutable", "append_only", "editable", "ephemeral", "mixed", "unknown"]
            },
            "deletion_rate": { "type": "string" },
            "decay_notes": { "type": "string" },
            "recrawl_cadence_hint": { "type": "string" }
          },
          "additionalProperties": false
        },
        "quality_signals": {
          "type": "object",
          "properties": {
            "official_trust_tiers": { "type": "string" },
            "spam_patterns": { "type": "string" },
            "manipulation_incentives": { "type": "string" }
          },
          "additionalProperties": false
        },
        "licensing_for_reuse": {
          "type": "string",
          "description": "What a third-party UI is allowed to show: snippets, thumbnails, embeds, transcripts."
        },
        "personalization": {
          "type": "object",
          "properties": {
            "logged_out_vs_in_differs": { "type": "boolean" },
            "anon_crawl_reflects_truth": { "type": "boolean" },
            "notes": { "type": "string" }
          },
          "additionalProperties": false
        },
        "region_language_splits": { "type": "string" },
        "internal_search_quality": { "type": "string" },
        "knowledge_graph_position": {
          "type": "string",
          "enum": ["hub", "sink", "balanced", "isolated", "unknown"]
        },
        "ranking_surface": {
          "type": "string",
          "description": "If someone wanted their content to surface here, what factors decide? Implies manipulation resistance."
        },
        "user_query_profile": {
          "type": "string",
          "description": "What does a typical query on this site look like? Which retrieval intents fit, which do not."
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk", "category"],
        "properties": {
          "risk": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["competition", "regulation", "platform_dependency", "security", "abuse", "business_model", "technology_shift", "reputation", "other"]
          },
          "likelihood": {
            "type": "string",
            "enum": ["low", "medium", "high", "materialized"]
          },
          "evidence": { "$ref": "#/$defs/evidence" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["audience", "lesson"],
        "properties": {
          "audience": {
            "type": "string",
            "enum": ["builder", "product", "engineering", "growth", "business", "investor", "retrieval", "general"]
          },
          "lesson": { "type": "string" },
          "evidence": { "$ref": "#/$defs/evidence" }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": { "type": "string" },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "publisher": { "type": "string" },
          "accessed_date": {
            "type": "string",
            "format": "date"
          },
          "tier": {
            "type": "string",
            "enum": ["primary", "official_secondary", "reputable_press", "analyst", "community", "self_published", "other"],
            "description": "Source quality tier. Primary = SEC filing, court doc, company financial. Official secondary = company blog. Reputable press = mainstream journalism. Analyst = research firm. Community = user posts. Self_published = personal blog / tweet."
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "description": "Date the profile was last reviewed for staleness. Older than 6 months should prompt a revisit."
    }
  },
  "additionalProperties": false
}
